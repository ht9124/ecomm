# ----------------------------------------------------------------------------
# Uygulama
# ----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Veritabanı (PostgreSQL) — docker-compose ile birebir uyumlu
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://ecomm:ecomm@localhost:5432/ecomm?schema=public

# ----------------------------------------------------------------------------
# Auth — JWT imzalama anahtarları (ZORUNLU)
# Her ortamda en az 32 karakterlik RASTGELE değer olmalıdır. Aşağıdaki
# __CHANGE_ME__ placeholder'ları uygulama tarafından REDDEDİLİR (fail-closed).
# Üretmek için:  openssl rand -hex 32
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=__CHANGE_ME__run_openssl_rand_hex_32
JWT_REFRESH_SECRET=__CHANGE_ME__run_openssl_rand_hex_32
ACCESS_TOKEN_TTL=900            # saniye (15 dk)
REFRESH_TOKEN_TTL=2592000       # saniye (30 gün)

# ----------------------------------------------------------------------------
# Ödeme sağlayıcı seçimi: iyzico | stripe
# ----------------------------------------------------------------------------
PAYMENT_PROVIDER=iyzico

# İyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Bildirim sağlayıcı seçimi: email -> sendgrid|mailgun|ses ; sms -> netgsm|twilio
# ----------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=no-reply@example.com
SENDGRID_API_KEY=

SMS_PROVIDER=netgsm
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=

# ----------------------------------------------------------------------------
# Medya / Depolama (S3 veya Cloudinary)
# ----------------------------------------------------------------------------
MEDIA_PROVIDER=cloudinary
CLOUDINARY_URL=
AWS_S3_BUCKET=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ----------------------------------------------------------------------------
# Kargo / Vergi / Promosyon kuralları
# ----------------------------------------------------------------------------
FREE_SHIPPING_THRESHOLD=750     # bu tutarın üzerinde kargo ücretsiz (KDV dahil, TL)
DEFAULT_SHIPPING_FEE=49.90
TAX_RATE=0.20                   # KDV %20 (fiyatlar KDV DAHİL gösterilir)
CURRENCY=TRY
PENDING_ORDER_TTL_MINUTES=30    # ödenmemiş siparişin stok/kupon rezervasyon süresi (K-3)

# ----------------------------------------------------------------------------
# İzleme / Hata takibi
# ----------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info

# Rate limiting (sürme penceresi)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
